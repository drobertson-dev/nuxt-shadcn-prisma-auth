{
  "name": "nuxt-shadcn-prisma-auth-starter",
  "version": "0.0.1",
  "description": "A Nuxt 4 starter template with shadcn-nuxt UI, Prisma ORM, Better Auth, and Resend email integration",
  "keywords": [
    "authentication",
    "better-auth",
    "boilerplate",
    "nuxt",
    "nuxt4",
    "prisma",
    "resend",
    "shadcn",
    "shadcn-vue",
    "starter-template",
    "tailwindcss",
    "vue"
  ],
  "homepage": "https://github.com/daver987/nuxt-shadcn-prisma-auth#readme",
  "bugs": {
    "url": "https://github.com/daver987/nuxt-shadcn-prisma-auth/issues"
  },
  "license": "MIT",
  "author": {
    "name": "David Robertson",
    "email": "info@drobertson.pro",
    "url": "https://github.com/daver987"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daver987/nuxt-shadcn-prisma-auth.git"
  },
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:prisma": "concurrently \"prisma dev\" \"nuxt dev\"",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "oxlint --type-aware --type-check",
    "life": "pnpm run format && pnpm run lint:fix && pnpm run type-check",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.12.1",
    "@nuxt/hints": "^1.0.0-alpha.5",
    "@nuxt/icon": "^2.1.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@unhead/vue": "^2.1.1",
    "@vueuse/core": "^14.1.0",
    "better-auth": "^1.4.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.562.0",
    "nuxt": "^4.2.2",
    "pg": "^8.16.3",
    "reka-ui": "^2.7.0",
    "resend": "^6.6.0",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.4.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.21.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/pg": "^8.16.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.2",
    "dotenv": "^17.2.3",
    "happy-dom": "^20.0.11",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "oxlint-tsgolint": "^0.10.1",
    "playwright-core": "^1.57.0",
    "prisma": "^7.2.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "zod": "^4.3.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm run lint"
  }
}
